# ── Authentication (pick one) ──────────────────────────────

# Option A: Client credentials (recommended — token auto-refreshes)
# Get these from Adobe Developer Console → Project → OAuth Server-to-Server
DA_CLIENT_ID=your_client_id_here
DA_CLIENT_SECRET=your_client_secret_here

# Option B: Direct IMS token (expires, must be rotated manually)
# DA_TOKEN=your_adobe_ims_token_here

# ── Project settings ──────────────────────────────────────

DA_ORG=angelaccenture
DA_REPO=aem-boilerplate-demo

# Server port (standalone mode only)
PORT=8787
